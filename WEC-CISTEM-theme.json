{
  "name": "WEC CISTEM Professional",
  "dataColors": [
    "#0E5E5E",
    "#16868A",
    "#3AA0A0",
    "#7BC6C6",
    "#C98A3E",
    "#B7615A",
    "#5B6B7B",
    "#9AA7B1"
  ],
  "foreground": "#1F2A30",
  "foregroundNeutralSecondary": "#51606B",
  "foregroundNeutralTertiary": "#8A98A2",
  "background": "#FFFFFF",
  "backgroundLight": "#F2F6F6",
  "backgroundNeutral": "#F2F6F6",
  "tableAccent": "#0E5E5E",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 11,
      "color": "#FFFFFF"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 9,
      "color": "#0E5E5E"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 9,
      "color": "#1F2A30"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 20,
      "color": "#0E5E5E"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "background": {
              "solid": {
                "color": "#0E5E5E"
              }
            },
            "alignment": "Left",
            "fontSize": 10,
            "bold": true
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D5E0E0"
              }
            },
            "radius": 5
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": {
              "solid": {
                "color": "#ECF1F1"
              }
            },
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#ECF1F1"
              }
            },
            "rowPadding": 2,
            "outlineColor": {
              "solid": {
                "color": "#D5E0E0"
              }
            },
            "outlineWeight": 1,
            "textSize": 9
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#0A4A4A"
              }
            },
            "backColor": {
              "solid": {
                "color": "#F2F6F6"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 9,
            "wordWrap": true,
            "alignment": "Left"
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#1F2A30"
              }
            },
            "backColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "wordWrap": true
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#0E5E5E"
              }
            },
            "fontSize": 18,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#51606B"
              }
            },
            "fontSize": 9
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#1F2A30"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}